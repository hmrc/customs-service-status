# microservice specific routes

PUT         /services/:id/status          uk.gov.hmrc.customsservicestatus.controllers.CustomsServiceStatusController.updateServiceStatus(id: String)
GET         /services                     uk.gov.hmrc.customsservicestatus.controllers.CustomsServiceStatusController.list()
GET         /services/planned-work        uk.gov.hmrc.customsservicestatus.controllers.AdminCustomsServiceStatusController.getAllPlannedWorks()
POST        /services/messages            uk.gov.hmrc.customsservicestatus.controllers.AdminCustomsServiceStatusController.updateWithOutageData()
GET         /outages                    uk.gov.hmrc.customsservicestatus.controllers.AdminCustomsServiceStatusController.findAllOutages()
GET         /outages/:id                uk.gov.hmrc.customsservicestatus.controllers.AdminCustomsServiceStatusController.findOutage(id: UUID)
GET         /outages/archive/:id         uk.gov.hmrc.customsservicestatus.controllers.AdminCustomsServiceStatusController.archiveOutage(id: UUID)